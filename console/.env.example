# Console build-time config (Vite). Copy to `.env` (or `.env.production`) to bake
# a default server address into the build. Users can still override it in the UI,
# and a value they've entered before is remembered.
#
# Production bundles should point at your hosted backend over wss://:
#   VITE_ARNA_BACKEND=wss://api.arna.ifleon.com/ws
#
# Dev leaves this unset and falls back to ws://127.0.0.1:8081/ws.
VITE_ARNA_BACKEND=
