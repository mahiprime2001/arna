# Copy to .env and fill in. Do NOT commit the real .env.

# Domains (must have A records pointing at the VPS)
WEBSITE_DOMAIN=arna.ifleon.com
API_DOMAIN=api.arna.ifleon.com
TURN_DOMAIN=turn.arna.ifleon.com

# coturn shared secret (also set in coturn/turnserver.conf). Generate with:
#   openssl rand -hex 32
TURN_STATIC_AUTH_SECRET=change-me-to-a-long-random-secret
TURN_REALM=arna.ifleon.com

# Backend
RUST_LOG=info
