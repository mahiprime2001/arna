# Copy to .env and fill in. Only ARNA_SSO_SECRET is required.

# Signs login sessions + device tokens. Use a long random value — generate one:
#   openssl rand -hex 32
ARNA_SSO_SECRET=change-me-to-a-long-random-secret

# Public port the server is reachable on (pick something unique on your VPS).
ARNA_PORT=48080

# --- Optional: TURN relay for cross-internet connections behind strict NATs ---
# Leave blank to use public STUN only (direct P2P; LAN-reliable). To run your
# own relay, fill these and point ARNA_TURN at a coturn you deploy.
# ARNA_STUN=stun:stun.l.google.com:19302
# ARNA_TURN=turn:your-vps-ip:3478
# ARNA_TURN_USER=arna
# ARNA_TURN_PASS=some-strong-password
